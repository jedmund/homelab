# {{ ansible_managed }}
name: {{ stack_name }}

services:
  sonarr:
    image: {{ sonarr_image }}
    container_name: sonarr
    restart: {{ restart_policy }}
    networks:
      - shared
    ports:
      - "{{ sonarr_port }}:8989"
    environment:
      - TZ={{ timezone }}
      - PUID={{ ansible_user_uid | default(1000) }}
      - PGID={{ ansible_user_gid | default(1000) }}
    volumes:
      - ./config:/config
      - television:/television
      - anime:/anime
      - downloads:/downloads
    healthcheck:
      test: ["CMD", "curl", "-fsS", "-o", "/dev/null", "http://localhost:8989/ping"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  television:
    name: television
    external: true
  anime:
    name: anime
    external: true
  downloads:
    name: downloads
    external: true

networks:
  shared:
    name: {{ shared_network }}
    external: true
