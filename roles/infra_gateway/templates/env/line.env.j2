# {{ ansible_managed }}
# Line environment variables - generated from Ansible Vault

HOST=0.0.0.0
PORT={{ line_port }}
PUBLIC_APP_URL={{ line_app_url }}
DATABASE_URL=/data/line.db
BACKUP_DIR={{ line_backup_dir }}

OIDC_ISSUER={{ line_oidc_issuer }}
OIDC_CLIENT_ID={{ line_oidc_client_id }}
OIDC_CLIENT_SECRET={{ line_oidc_client_secret }}
OIDC_REDIRECT_URI={{ line_oidc_redirect_uri }}

# widget_token_key - defined in vault (optional, falls back to OIDC_CLIENT_SECRET)
WIDGET_TOKEN_KEY={{ line_widget_token_key | default('') }}

# reddit_client_id - defined in vault
REDDIT_CLIENT_ID={{ line_reddit_client_id | default('') }}

# twitch_client_id, twitch_client_secret - defined in vault
TWITCH_CLIENT_ID={{ line_twitch_client_id | default('') }}
TWITCH_CLIENT_SECRET={{ line_twitch_client_secret | default('') }}

# bart_api_key - defined in vault
BART_API_KEY={{ line_bart_api_key | default('') }}

# bay_511_api_key - defined in vault
BAY_511_API_KEY={{ line_bay_511_api_key | default('') }}
