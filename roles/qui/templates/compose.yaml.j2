# {{ ansible_managed }}
name: {{ stack_name }}

services:
  qui:
    image: {{ qui_image }}
    container_name: qui
    restart: {{ restart_policy }}
    networks:
      - proxy
    env_file:
      - ./env/qui.env
    volumes:
      - ./config:/config
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.qui.rule=Host(`{{ qui_domain }}`)"
      - "traefik.http.routers.qui.entrypoints=websecure"
      - "traefik.http.routers.qui.tls.certresolver=letsencrypt"
      - "traefik.http.services.qui.loadbalancer.server.port={{ qui_port }}"
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:7476"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

networks:
  proxy:
    name: {{ proxy_network }}
    external: true
