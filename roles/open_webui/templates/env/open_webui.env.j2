# {{ ansible_managed }}
# Open WebUI environment

OLLAMA_BASE_URL={{ open_webui_ollama_base_url }}
OPENAI_API_BASE_URL={{ open_webui_openai_api_base_url }}
WEBUI_AUTH={{ open_webui_auth }}
WEBUI_URL={{ open_webui_url }}
WEBUI_SECRET_KEY={{ open_webui_secret_key }}

ENABLE_API_KEYS=true
ENABLE_API_KEYS_ENDPOINT_RESTRICTIONS=true
ENABLE_OAUTH_SIGNUP={{ open_webui_oauth_signup }}
OAUTH_MERGE_ACCOUNTS_BY_EMAIL={{ open_webui_oauth_merge_accounts }}
OAUTH_PROVIDER_NAME={{ open_webui_oauth_provider_name }}
OPENID_PROVIDER_URL={{ open_webui_oidc_provider_url }}
OAUTH_CLIENT_ID={{ open_webui_oauth_client_id }}
OAUTH_CLIENT_SECRET={{ open_webui_oauth_client_secret }}
OAUTH_SCOPES={{ open_webui_oauth_scopes }}

AUDIO_STT_ENGINE=openai
AUDIO_STT_OPENAI_API_BASE_URL={{ open_webui_audio_stt_base_url }}
AUDIO_STT_OPENAI_API_KEY=sk-no-key-required
AUDIO_STT_MODEL=Systran/faster-distil-whisper-large-v3

AUDIO_TTS_ENGINE=openai
AUDIO_TTS_OPENAI_API_BASE_URL={{ open_webui_audio_tts_base_url }}
AUDIO_TTS_OPENAI_API_KEY=sk-no-key-required
AUDIO_TTS_MODEL=kokoro
AUDIO_TTS_VOICE={{ open_webui_audio_tts_voice }}

ENABLE_RAG_WEB_SEARCH=true
RAG_WEB_SEARCH_ENGINE=searxng
SEARXNG_QUERY_URL={{ open_webui_searxng_query_url }}

WEB_LOADER_ENGINE={{ open_webui_web_loader_engine }}
PLAYWRIGHT_WS_URL={{ open_webui_playwright_ws_url }}

RAG_EMBEDDING_ENGINE=openai
RAG_OPENAI_API_BASE_URL={{ open_webui_rag_embedding_base_url }}
RAG_OPENAI_API_KEY=sk-no-key-required
RAG_EMBEDDING_MODEL={{ open_webui_rag_embedding_model }}
