# {{ ansible_managed }}
# Vane runtime environment. Secrets are sourced from Ansible vault.

# Vane's entrypoint runs `node server.js` (Next.js standalone) rather than
# `next start`, which means NODE_ENV is unset by default. Our session
# cookie's Secure attribute is gated on NODE_ENV=production.
NODE_ENV=production

# Reuse max's SearXNG instead of the bundled one in Vane's image.
SEARXNG_API_URL={{ vane_searxng_url }}

# OIDC against PocketID; redirect URI must match what is registered in
# PocketID admin.
OIDC_ISSUER_URL={{ vane_oidc_issuer_url }}
OIDC_CLIENT_ID={{ vane_oidc_client_id }}
OIDC_CLIENT_SECRET={{ vane_oidc_client_secret }}
OIDC_SCOPES={{ vane_oidc_scopes }}
OIDC_REDIRECT_URI={{ vane_oidc_redirect_uri }}

# Signs the state cookie HMAC and seeds session-token randomness. Min 16
# chars enforced by the app; the fork errors at boot if shorter.
SESSION_SECRET={{ vane_session_secret }}
SESSION_TTL_SECONDS={{ vane_session_ttl_seconds }}
APP_ORIGIN={{ vane_app_origin }}
