# {{ ansible_managed }}
# slskdN (Soulseek) environment variables — secrets sourced from vault

# Soulseek credentials
# slskd_slsk_username - defined in vault
# slskd_slsk_password - defined in vault
SLSKD_SLSK_USERNAME={{ slskd_slsk_username }}
SLSKD_SLSK_PASSWORD={{ slskd_slsk_password }}

# Web UI admin login (tinyauth SSO sits in front; this is slskd's own login)
# slskd_web_username - defined in vault
# slskd_web_password - defined in vault
SLSKD_USERNAME={{ slskd_web_username }}
SLSKD_PASSWORD={{ slskd_web_password }}

# Shared directories (semicolon-separated, optional [Alias] prefix)
SLSKD_SHARED_DIR=[Music]/music
