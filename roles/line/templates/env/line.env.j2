# {{ ansible_managed }}
# Line runtime environment. Secrets are sourced from Ansible vault.

HOST=0.0.0.0
PORT={{ line_port }}
PUBLIC_APP_URL={{ line_app_url }}
DATABASE_URL=/data/line.db
BACKUP_DIR={{ line_backup_dir }}
LINE_ADMIN_EMAILS={{ line_admin_emails }}

OIDC_ISSUER={{ line_oidc_issuer }}
OIDC_CLIENT_ID={{ line_oidc_client_id }}
OIDC_CLIENT_SECRET={{ line_oidc_client_secret }}
OIDC_REDIRECT_URI={{ line_oidc_redirect_uri }}

# Optional widget/API integrations.
WIDGET_TOKEN_KEY={{ line_widget_token_key }}
REDDIT_CLIENT_ID={{ line_reddit_client_id }}
TWITCH_CLIENT_ID={{ line_twitch_client_id }}
TWITCH_CLIENT_SECRET={{ line_twitch_client_secret }}
YOUTUBE_API_KEY={{ line_youtube_api_key }}
BART_API_KEY={{ line_bart_api_key }}
BAY_511_API_KEY={{ line_bay_511_api_key }}
GITHUB_OAUTH_CLIENT_ID={{ line_github_oauth_client_id }}
GITHUB_OAUTH_CLIENT_SECRET={{ line_github_oauth_client_secret }}
