# {{ ansible_managed }}
name: {{ stack_name }}

services:
  immich-server:
    container_name: immich_server
    image: {{ immich_server_image }}
    volumes:
      - photos:/usr/src/app/upload
      - /etc/localtime:/etc/localtime:ro
    env_file:
      - ./env/immich.env
    ports:
      - '{{ immich_port }}:2283'
    depends_on:
      - immich-redis
      - immich-database
    restart: always
    healthcheck:
      disable: false

  immich-machine-learning:
    container_name: immich_machine_learning
    image: {{ immich_ml_image }}
    volumes:
      - model-cache:/cache
    env_file:
      - ./env/immich.env
    restart: always
    healthcheck:
      disable: false

  immich-redis:
    container_name: immich_redis
    image: {{ immich_redis_image }}
    healthcheck:
      test: redis-cli ping || exit 1
    restart: always

  immich-database:
    container_name: immich_postgres
    image: {{ immich_db_image }}
    env_file:
      - ./env/immich.env
    volumes:
      - immich-pgdata:/var/lib/postgresql/data
    restart: always

  papra:
    container_name: papra
    image: {{ papra_image }}
    restart: {{ restart_policy }}
    user: "{{ puid }}:{{ pgid }}"
    ports:
      - "{{ papra_external_port }}:{{ papra_port }}"
    volumes:
      - ./config/papra:/app/app-data
    env_file:
      - ./env/papra.env
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  songkong:
    container_name: songkong
    image: {{ songkong_image }}
    restart: {{ restart_policy }}
    ports:
      - "{{ songkong_port }}:4567"
    volumes:
      - songkong-config:/songkong
      - music:/music
    environment:
      - TZ={{ timezone }}

  homebox:
    container_name: homebox
    image: {{ homebox_image }}
    restart: {{ restart_policy }}
    ports:
      - "{{ homebox_external_port }}:7745"
    volumes:
      - ./config/homebox:/data
    env_file:
      - ./env/homebox.env
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  album-sort:
    container_name: album_sort
    build: {{ album_sort_source_path }}
    image: {{ stack_name }}/album-sort:local
    restart: {{ restart_policy }}
    ports:
      - {{ album_sort_port }}:{{ album_sort_container_port }}
    env_file:
      - ./env/album-sort.env
    environment:
      - TZ={{ timezone }}
      - ORIGIN={{ album_sort_origin }}
      - UNSORTED_PATH={{ album_sort_unsorted_path }}
      - SORTED_PATH={{ album_sort_sorted_path }}
      - DATA_PATH={{ album_sort_data_path }}
      - WATCH_INTERVAL={{ album_sort_watch_interval }}
      - BEETS_WEB_URL=http://beets:8337
      - BEETS_API_URL=http://beets:8338
    volumes:
      - music:/music
      - ./album-sort-data:/data
    depends_on:
      - beets
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  beets:
    container_name: album_sort_beets
    build: {{ album_sort_source_path }}/deploy/beets
    image: {{ stack_name }}/beets:local
    restart: {{ restart_policy }}
    environment:
      - TZ={{ timezone }}
      - MUSIC_SORTED_PATH={{ album_sort_sorted_path }}
    volumes:
      - music:/music
      - ./album-sort-beets-data:/data/beets
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  dawarich-app:
    container_name: dawarich_app
    image: {{ dawarich_image }}
    restart: {{ restart_policy }}
    env_file:
      - ./env/dawarich.env
    ports:
      - "{{ dawarich_external_port }}:3000"
    stdin_open: true
    tty: true
    entrypoint: web-entrypoint.sh
    command: ['bin/rails', 'server', '-p', '3000', '-b', '::']
    volumes:
      - dawarich-public:/var/app/public
      - dawarich-watched:/var/app/tmp/imports/watched
      - dawarich-storage:/var/app/storage
      - dawarich-db-data:/dawarich_db_data
    depends_on:
      dawarich-db:
        condition: service_healthy
        restart: true
      dawarich-redis:
        condition: service_healthy
        restart: true
    healthcheck:
      # APPLICATION_PROTOCOL=https makes Rails 301-redirect plain HTTP to HTTPS,
      # which wget cannot satisfy against non-TLS Puma. Send X-Forwarded-Proto
      # so force_ssl treats the probe as already-secure.
      test: ["CMD-SHELL", "curl -fsS -H 'X-Forwarded-Proto: https' http://127.0.0.1:3000/api/v1/health | grep -q '\"status\".*ok'"]
      interval: 10s
      timeout: 10s
      retries: 30
      start_period: 60s
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  dawarich-sidekiq:
    container_name: dawarich_sidekiq
    image: {{ dawarich_image }}
    restart: {{ restart_policy }}
    env_file:
      - ./env/dawarich.env
    stdin_open: true
    tty: true
    entrypoint: sidekiq-entrypoint.sh
    command: ['sidekiq']
    volumes:
      - dawarich-public:/var/app/public
      - dawarich-watched:/var/app/tmp/imports/watched
      - dawarich-storage:/var/app/storage
    depends_on:
      dawarich-db:
        condition: service_healthy
        restart: true
      dawarich-redis:
        condition: service_healthy
        restart: true
      dawarich-app:
        condition: service_healthy
        restart: true
    healthcheck:
      test: ["CMD-SHELL", "pgrep -f sidekiq"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  dawarich-db:
    container_name: dawarich_postgres
    image: {{ dawarich_db_image }}
    restart: {{ restart_policy }}
    shm_size: 1g
    environment:
      POSTGRES_USER: {{ dawarich_db_username }}
      POSTGRES_PASSWORD: {{ dawarich_db_password }}
      POSTGRES_DB: {{ dawarich_db_name }}
    volumes:
      - dawarich-db-data:/var/lib/postgresql/data
      - dawarich-shared:/var/shared
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ dawarich_db_username }} -d {{ dawarich_db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  dawarich-redis:
    container_name: dawarich_redis
    image: {{ dawarich_redis_image }}
    restart: {{ restart_policy }}
    command: >
      redis-server
      --save 900 1
      --save 300 10
      --appendonly no
    volumes:
      - dawarich-shared:/data
    healthcheck:
      test: ["CMD", "redis-cli", "--raw", "incr", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  dawarich-photon:
    container_name: dawarich_photon
    image: {{ dawarich_photon_image }}
    restart: {{ restart_policy }}
    environment:
      - REGION={{ dawarich_photon_region }}
      - INITIAL_DOWNLOAD={{ dawarich_photon_initial_download }}
    volumes:
      - dawarich-photon-data:/photon/data
    healthcheck:
      test: ["CMD-SHELL", "wget --spider -q http://127.0.0.1:2322/api?q=test"]
      interval: 60s
      timeout: 10s
      retries: 10
      start_period: 60m
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  immich-pgdata:
    external: true
    name: immich-pgdata
  model-cache:
  songkong-config:

  photos:
    external: true
  music:
    external: true

  dawarich-db-data:
  dawarich-shared:
  dawarich-public:
  dawarich-watched:
  dawarich-storage:
  dawarich-photon-data:

networks:
  default:
    name: {{ shared_network }}
    external: true
