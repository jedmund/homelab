# {{ ansible_managed }}
# Dawarich environment variables - generated from Ansible Vault
# Shared by dawarich-app (web) and dawarich-sidekiq (worker)

# App
RAILS_ENV={{ dawarich_rails_env }}
SELF_HOSTED={{ dawarich_self_hosted }}
APPLICATION_HOSTS={{ dawarich_domain }}
APPLICATION_PROTOCOL=https
TIME_ZONE={{ timezone }}
RAILS_LOG_TO_STDOUT={{ dawarich_log_to_stdout }}
STORE_GEODATA={{ dawarich_store_geodata }}
BACKGROUND_PROCESSING_CONCURRENCY={{ dawarich_background_processing_concurrency }}
# dawarich_secret_key_base - defined in vault
SECRET_KEY_BASE={{ dawarich_secret_key_base }}

# Database
DATABASE_HOST={{ dawarich_db_host }}
DATABASE_PORT={{ dawarich_db_port }}
DATABASE_USERNAME={{ dawarich_db_username }}
DATABASE_NAME={{ dawarich_db_name }}
# dawarich_db_password - defined in vault
DATABASE_PASSWORD={{ dawarich_db_password }}

# Redis
REDIS_URL={{ dawarich_redis_url }}

# Reverse geocoding (self-hosted Photon, worldwide index)
PHOTON_API_HOST={{ dawarich_photon_api_host }}
PHOTON_API_USE_HTTPS={{ dawarich_photon_api_use_https }}

# OIDC (PocketID)
OIDC_PROVIDER_NAME={{ dawarich_oidc_provider_name }}
OIDC_ISSUER={{ dawarich_oidc_issuer }}
# dawarich_oidc_client_id - defined in vault
OIDC_CLIENT_ID={{ dawarich_oidc_client_id }}
# dawarich_oidc_client_secret - defined in vault
OIDC_CLIENT_SECRET={{ dawarich_oidc_client_secret }}
OIDC_REDIRECT_URI={{ dawarich_oidc_redirect_uri }}
OIDC_AUTO_REGISTER={{ dawarich_oidc_auto_register }}
ALLOW_EMAIL_PASSWORD_REGISTRATION={{ dawarich_allow_email_password_registration }}

# SMTP (SendGrid via shared key)
SMTP_SERVER={{ dawarich_smtp_server }}
SMTP_PORT={{ dawarich_smtp_port }}
SMTP_DOMAIN={{ dawarich_smtp_domain }}
SMTP_USERNAME={{ dawarich_smtp_username }}
# sendgrid_api_key - defined in compute_servers vault (shared across stacks)
SMTP_PASSWORD={{ sendgrid_api_key }}
SMTP_FROM={{ dawarich_smtp_from }}
SMTP_STARTTLS={{ dawarich_smtp_starttls }}
SMTP_AUTHENTICATION={{ dawarich_smtp_authentication }}
