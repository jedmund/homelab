# {{ ansible_managed }}
name: {{ stack_name }}

services:
  n8n:
    container_name: n8n
    image: {{ n8n_image }}
    restart: {{ restart_policy }}
    networks:
      - proxy
      - backend
    volumes:
      - n8n-data:/home/node/.n8n
    env_file:
      - ./env/n8n.env
    depends_on:
      n8n-db:
        condition: service_healthy
    labels:
      traefik.enable: "true"
      traefik.http.routers.n8n.rule: "Host(`{{ n8n_domain }}`)"
      traefik.http.routers.n8n.entrypoints: "websecure"
      traefik.http.routers.n8n.tls.certresolver: "letsencrypt"
      traefik.http.services.n8n.loadbalancer.server.port: "{{ n8n_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  n8n-db:
    container_name: n8n_postgres
    image: {{ n8n_db_image }}
    restart: {{ restart_policy }}
    networks:
      - backend
    volumes:
      - n8n-pgdata:/var/lib/postgresql/data
    env_file:
      - ./env/n8n-db.env
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "{{ n8n_db_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: "5m"
        max-file: {{ logging_max_file }}

  changedetection:
    container_name: changedetection
    image: {{ changedetection_image }}
    restart: {{ restart_policy }}
    networks:
      - proxy
    volumes:
      - ./config/changedetection:/datastore
    environment:
      - TZ={{ timezone }}
      - PORT={{ changedetection_port }}
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ changedetection_port }}').read()"]
      interval: 30s
      timeout: 10s
      retries: 3
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  copyparty:
    container_name: copyparty
    image: {{ copyparty_image }}
    restart: {{ restart_policy }}
    user: "{{ puid }}:{{ pgid }}"
    networks:
      - proxy
    volumes:
      - ./config/copyparty:/cfg
      - videos:/w/Videos
      - music:/w/Music
      - downloads:/w/Downloads
      - photos:/w/Photos
      - comics:/w/Comics
      - games:/w/Games
    environment:
      - TZ={{ timezone }}
      - HOME=/cfg
      - XDG_CONFIG_HOME=/cfg
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:{{ copyparty_port }}"]
      interval: 30s
      timeout: 10s
      retries: 3
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  # feederhub — see roles/utilities/defaults/main.yml for the
  # `network_mode: host` rationale.  No traefik labels: routing is
  # handled by the file provider in
  # roles/infra_gateway/templates/traefik/dynamic/services-mini.yml.j2
  # (search for `feederhub` there).
  feederhub:
    container_name: feederhub
    image: "{{ feederhub_image }}:{{ feederhub_image_tag }}"
    restart: {{ restart_policy }}
    network_mode: host
    env_file:
      - ./env/feederhub.env
    volumes:
      - ./config/feederhub:/data
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  vane:
    container_name: vane
    build:
      context: ./vane-src
      args:
        # Next.js bakes CSP at build time; passing OIDC_ISSUER_URL as a
        # build-arg ensures the IdP host lands in connect-src / form-action.
        # If the Vane Dockerfile does not yet declare ARG OIDC_ISSUER_URL,
        # this is harmless (build-arg is ignored) but the server logs
        # "OIDC_ISSUER_URL not set; CSP connect-src/form-action will not
        # include an IdP origin" on startup. OIDC still works because the
        # PocketID round-trip is 302 redirects, not browser fetches.
        OIDC_ISSUER_URL: "{{ vane_oidc_issuer_url }}"
    restart: {{ restart_policy }}
    networks:
      - proxy
    volumes:
      - vane-data:/home/vane/data
    environment:
      # Reuse max's SearXNG instead of the bundled one in Vane's image.
      - SEARXNG_API_URL={{ vane_searxng_url }}
      # OIDC against PocketID; redirect URI must match what is registered
      # in PocketID admin.
      - OIDC_ISSUER_URL={{ vane_oidc_issuer_url }}
      - OIDC_CLIENT_ID={{ vane_oidc_client_id }}
      - OIDC_CLIENT_SECRET={{ vane_oidc_client_secret }}
      - OIDC_SCOPES={{ vane_oidc_scopes }}
      - OIDC_REDIRECT_URI={{ vane_oidc_redirect_uri }}
      # Signs the state cookie HMAC and seeds session-token randomness.
      # Min 16 chars enforced by the app; the fork errors at boot if shorter.
      - SESSION_SECRET={{ vane_session_secret }}
      - SESSION_TTL_SECONDS={{ vane_session_ttl_seconds }}
    labels:
      # Native OIDC handles auth; no tinyauth middleware on this route.
      traefik.enable: "true"
      traefik.http.routers.vane.rule: "Host(`{{ vane_domain }}`)"
      traefik.http.routers.vane.entrypoints: "websecure"
      traefik.http.routers.vane.tls.certresolver: "letsencrypt"
      traefik.http.services.vane.loadbalancer.server.port: "{{ vane_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  n8n-data:
    external: true
  n8n-pgdata:
    external: true
  videos:
    external: true
  music:
    external: true
  downloads:
    external: true
  photos:
    external: true
  comics:
    external: true
  games:
    external: true
  vane-data:

networks:
  proxy:
    name: {{ proxy_network }}
    external: true
  backend:
    name: {{ backend_network }}
    external: true
