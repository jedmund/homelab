# {{ ansible_managed }}
# feederhub environment.  Mirror of /Users/justin/Developer/PetLibro/
# feederhub/.env.example with values injected from defaults +
# group_vars/utilities/vault.yml.

FEEDERHUB_LISTEN=:{{ feederhub_host_port }}
FEEDERHUB_LOG_LEVEL=info
FEEDERHUB_DB_PATH=/data/feederhub.db
FEEDERHUB_TIMEZONE={{ timezone }}

# MQTT — petlibro-mosquitto publishes on the host's 0.0.0.0:1883,
# and feederhub runs with `network_mode: host`, so loopback works.
FEEDERHUB_MQTT_URL=tcp://127.0.0.1:1883

# Topic prefixes — these are fixed by the PLAF203 firmware.
FEEDERHUB_HA_DISCOVERY_PREFIX=homeassistant
FEEDERHUB_PETLIBRO_TOPIC_PREFIX=dl/PLAF203
FEEDERHUB_BRIDGE_PREFIX=feederhub

# Tuning — defaults proven during the Phase 3 + 4 smoke runs.
FEEDERHUB_HANDSHAKE_DEBOUNCE_MS=2000
FEEDERHUB_NTP_SYNC_THRESHOLD_MS=5000
FEEDERHUB_CALIBRATION_TOLERANCE_MS=200

# TUTK (Kalay) cloud credentials — sourced from vault.
FEEDERHUB_TUTK_SERVER={{ feederhub_tutk_server }}
FEEDERHUB_TUTK_USERNAME={{ feederhub_tutk_username }}
FEEDERHUB_TUTK_PASSWORD={{ feederhub_tutk_password }}

# Feeders inventory — `device_id:uid:name` triples, comma-separated.
FEEDERHUB_FEEDERS={{ feederhub_feeders }}

# Cloud bridge — off.  The whole point of feederhub is that the
# Petlibro app's cloud session continues to work AS LONG AS the
# UDM DNAT keeps redirecting the device-side MQTT to our broker.
FEEDERHUB_CLOUD_BRIDGE_ENABLED=false

# ONVIF Profile-S responder — feederhub Phase 8.  USER/PASS are the
# credentials Protect prompts for at adoption time; PORT_BASE allocates
# one SOAP listener per feeder; ADVERTISE_HOST is the LAN address
# Protect uses to reach us.
FEEDERHUB_ONVIF_ENABLED={{ feederhub_onvif_enabled | string | lower }}
FEEDERHUB_ONVIF_USER={{ feederhub_onvif_user }}
FEEDERHUB_ONVIF_PASS={{ feederhub_onvif_pass }}
FEEDERHUB_ONVIF_PORT_BASE={{ feederhub_onvif_port_base }}
FEEDERHUB_ONVIF_ADVERTISE_HOST={{ feederhub_onvif_advertise_host }}
