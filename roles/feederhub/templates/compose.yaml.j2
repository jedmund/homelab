# {{ ansible_managed }}
name: {{ stack_name }}

services:
  # feederhub — see roles/feederhub/defaults/main.yml for the
  # `network_mode: host` rationale.  No traefik labels: routing is
  # handled by the file provider in
  # roles/infra_gateway/templates/traefik/dynamic/services-mini.yml.j2
  # (search for `feederhub` there).
  feederhub:
    container_name: feederhub
    image: "{{ feederhub_image }}:{{ feederhub_image_tag }}"
    restart: {{ restart_policy }}
    network_mode: host
    # Distroless `nonroot` (uid 65532) needs CAP_NET_BIND_SERVICE to
    # bind the ONVIF SOAP listeners on port 80 (one per feeder VIP).
    # Without it the binary boots fine on 8554/8555/18080 but
    # ListenAndServe on :80 fails with "permission denied".
    cap_add:
      - NET_BIND_SERVICE
    env_file:
      - ./env/feederhub.env
    volumes:
      - ./config/feederhub:/data
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}
