# {{ ansible_managed }}
name: {{ stack_name }}

services:
  copyparty:
    container_name: copyparty
    image: {{ copyparty_image }}
    restart: {{ restart_policy }}
    user: "{{ puid }}:{{ pgid }}"
    networks:
      - proxy
    volumes:
      - ./config:/cfg
      - videos:/w/Videos
      - music:/w/Music
      - downloads:/w/Downloads
      - photos:/w/Photos
      - comics:/w/Comics
      - games:/w/Games
    environment:
      - TZ={{ timezone }}
      - HOME=/cfg
      - XDG_CONFIG_HOME=/cfg
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:{{ copyparty_port }}"]
      interval: 30s
      timeout: 10s
      retries: 3
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  videos:
    name: videos
    external: true
  music:
    name: music
    external: true
  downloads:
    name: downloads
    external: true
  photos:
    name: photos
    external: true
  comics:
    name: comics
    external: true
  games:
    name: games
    external: true

networks:
  proxy:
    name: {{ proxy_network }}
    external: true
