# {{ ansible_managed }}
# Openclaw gateway environment. Loaded by the launchd-managed daemon at
# startup; secrets referenced from openclaw.json via
# { source: "env", id: "<NAME>" } resolve against the variables here.
# Skill bins (goplaces, etc.) read their API keys directly from the
# environment, so any KEY=VALUE line below is reachable to them.
{% if openclaw_discord_enabled %}

DISCORD_BOT_TOKEN={{ openclaw_discord_bot_token }}
{% endif %}
{% if openclaw_goplaces_enabled %}

GOOGLE_PLACES_API_KEY={{ openclaw_google_places_api_key }}
{% endif %}
