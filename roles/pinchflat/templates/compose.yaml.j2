# {{ ansible_managed }}
name: {{ stack_name }}

services:
  pinchflat:
    image: {{ pinchflat_image }}
    container_name: pinchflat
    restart: {{ restart_policy }}
    networks:
      - shared
    ports:
      - "{{ pinchflat_port }}:8945"
    environment:
      - TZ={{ timezone }}
    volumes:
      - ./config:/config
      - downloads:/downloads
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8945"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  downloads:
    name: downloads
    external: true

networks:
  shared:
    name: {{ shared_network }}
    external: true
