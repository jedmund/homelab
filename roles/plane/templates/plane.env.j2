# {{ ansible_managed }}
# Plane Community Edition environment.
# Read by docker compose for ${VAR} substitution into compose.yaml anchors.

APP_RELEASE={{ plane_app_release }}

# Replica counts (single-node homelab)
WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1

# Ingress: Plane's nginx proxy listens on 80 internally; Traefik fronts TLS.
NGINX_PORT=80

# Public URLs (single domain, path-routed by Plane's proxy)
WEB_URL=https://{{ plane_domain }}
APP_BASE_URL=https://{{ plane_domain }}
SPACE_BASE_URL=https://{{ plane_domain }}/spaces
ADMIN_BASE_URL=https://{{ plane_domain }}/god-mode
CORS_ALLOWED_ORIGINS=https://{{ plane_domain }}
API_BASE_URL=http://api:8000

DEBUG=0
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
GUNICORN_WORKERS={{ plane_gunicorn_workers }}

# Django secret
SECRET_KEY={{ plane_secret_key }}

# Postgres. DATABASE_URL must be set explicitly so the password matches;
# leaving it blank makes the app fall back to the upstream default of "plane".
PGHOST=plane-db
PGDATABASE={{ plane_postgres_db }}
POSTGRES_USER={{ plane_postgres_user }}
POSTGRES_PASSWORD={{ plane_postgres_password }}
POSTGRES_DB={{ plane_postgres_db }}
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data
DATABASE_URL=postgresql://{{ plane_postgres_user }}:{{ plane_postgres_password }}@plane-db/{{ plane_postgres_db }}

# Redis / Valkey
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# RabbitMQ. AMQP_URL set explicitly for the same password reason as Postgres.
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER={{ plane_rabbitmq_user }}
RABBITMQ_PASSWORD={{ plane_rabbitmq_password }}
RABBITMQ_VHOST={{ plane_rabbitmq_vhost }}
AMQP_URL=amqp://{{ plane_rabbitmq_user }}:{{ plane_rabbitmq_password }}@plane-mq:5672/{{ plane_rabbitmq_vhost }}

# Object storage (bundled MinIO)
USE_MINIO={{ plane_use_minio }}
AWS_REGION=
AWS_ACCESS_KEY_ID={{ plane_minio_access_key }}
AWS_SECRET_ACCESS_KEY={{ plane_minio_secret_key }}
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME={{ plane_s3_bucket }}
FILE_SIZE_LIMIT={{ plane_file_size_limit }}
