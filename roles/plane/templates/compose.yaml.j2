# {{ ansible_managed }}
name: {{ stack_name }}

# Adapted from upstream deploy/selfhost/docker-compose.yml. Changes:
#   - logging block + restart policy from homelab common vars
#   - all services on a stack-local default network (generic names like
#     api/web/worker must not collide on the shared backend network)
#   - proxy additionally joined to the external Traefik proxy network, host
#     port publish removed, Traefik labels added (single domain, TLS at Traefik)
# Config/secrets come from ./.env (templated, 0600) via ${VAR} substitution.

x-logging: &plane-logging
  driver: {{ logging_driver }}
  options:
    max-size: {{ logging_max_size }}
    max-file: {{ logging_max_file }}

x-db-env: &db-env
  PGHOST: ${PGHOST:-plane-db}
  PGDATABASE: ${PGDATABASE:-plane}
  POSTGRES_USER: ${POSTGRES_USER:-plane}
  POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-plane}
  POSTGRES_DB: ${POSTGRES_DB:-plane}
  POSTGRES_PORT: ${POSTGRES_PORT:-5432}
  PGDATA: ${PGDATA:-/var/lib/postgresql/data}

x-redis-env: &redis-env
  REDIS_HOST: ${REDIS_HOST:-plane-redis}
  REDIS_PORT: ${REDIS_PORT:-6379}
  REDIS_URL: ${REDIS_URL:-redis://plane-redis:6379/}

x-minio-env: &minio-env
  MINIO_ROOT_USER: ${AWS_ACCESS_KEY_ID:-access-key}
  MINIO_ROOT_PASSWORD: ${AWS_SECRET_ACCESS_KEY:-secret-key}

x-aws-s3-env: &aws-s3-env
  AWS_REGION: ${AWS_REGION:-}
  AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID:-access-key}
  AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY:-secret-key}
  AWS_S3_ENDPOINT_URL: ${AWS_S3_ENDPOINT_URL:-http://plane-minio:9000}
  AWS_S3_BUCKET_NAME: ${AWS_S3_BUCKET_NAME:-uploads}

x-proxy-env: &proxy-env
  NGINX_PORT: ${NGINX_PORT:-80}
  BUCKET_NAME: ${AWS_S3_BUCKET_NAME:-uploads}
  FILE_SIZE_LIMIT: ${FILE_SIZE_LIMIT:-5242880}

x-mq-env: &mq-env
  RABBITMQ_HOST: ${RABBITMQ_HOST:-plane-mq}
  RABBITMQ_PORT: ${RABBITMQ_PORT:-5672}
  RABBITMQ_DEFAULT_USER: ${RABBITMQ_USER:-plane}
  RABBITMQ_DEFAULT_PASS: ${RABBITMQ_PASSWORD:-plane}
  RABBITMQ_DEFAULT_VHOST: ${RABBITMQ_VHOST:-plane}
  RABBITMQ_VHOST: ${RABBITMQ_VHOST:-plane}

x-live-env: &live-env
  API_BASE_URL: ${API_BASE_URL:-http://api:8000}

x-app-env: &app-env
  WEB_URL: ${WEB_URL:-http://localhost}
  DEBUG: ${DEBUG:-0}
  SENTRY_DSN: ${SENTRY_DSN}
  SENTRY_ENVIRONMENT: ${SENTRY_ENVIRONMENT:-production}
  CORS_ALLOWED_ORIGINS: ${CORS_ALLOWED_ORIGINS}
  GUNICORN_WORKERS: ${GUNICORN_WORKERS:-1}
  USE_MINIO: ${USE_MINIO:-1}
  DATABASE_URL: ${DATABASE_URL:-postgresql://plane:plane@plane-db/plane}
  SECRET_KEY: ${SECRET_KEY:-60gp0byfz2dvffa45cxl20p1scy9xbpf6d8c5y0geejgkyp1b5}
  ADMIN_BASE_URL: ${ADMIN_BASE_URL}
  SPACE_BASE_URL: ${SPACE_BASE_URL}
  APP_BASE_URL: ${APP_BASE_URL}
  AMQP_URL: ${AMQP_URL:-amqp://plane:plane@plane-mq:5672/plane}

services:
  web:
    container_name: plane_web
    image: makeplane/plane-frontend:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    command: node web/server.js web
    depends_on:
      - api
      - worker
    logging: *plane-logging

  space:
    container_name: plane_space
    image: makeplane/plane-space:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    command: node space/server.js space
    depends_on:
      - api
      - worker
      - web
    logging: *plane-logging

  admin:
    container_name: plane_admin
    image: makeplane/plane-admin:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    command: node admin/server.js admin
    depends_on:
      - api
      - web
    logging: *plane-logging

  live:
    container_name: plane_live
    image: makeplane/plane-live:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    command: node live/dist/server.js live
    environment:
      <<: [*live-env]
    depends_on:
      - api
      - web
    logging: *plane-logging

  api:
    container_name: plane_api
    image: makeplane/plane-backend:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    command: ./bin/docker-entrypoint-api.sh
    volumes:
      - logs_api:/code/plane/logs
    environment:
      <<: [*app-env, *db-env, *redis-env, *minio-env, *aws-s3-env, *proxy-env]
    depends_on:
      - plane-db
      - plane-redis
      - plane-mq
    logging: *plane-logging

  worker:
    container_name: plane_worker
    image: makeplane/plane-backend:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    command: ./bin/docker-entrypoint-worker.sh
    volumes:
      - logs_worker:/code/plane/logs
    environment:
      <<: [*app-env, *db-env, *redis-env, *minio-env, *aws-s3-env, *proxy-env]
    depends_on:
      - api
      - plane-db
      - plane-redis
      - plane-mq
    logging: *plane-logging

  beat-worker:
    container_name: plane_beat_worker
    image: makeplane/plane-backend:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    command: ./bin/docker-entrypoint-beat.sh
    volumes:
      - logs_beat-worker:/code/plane/logs
    environment:
      <<: [*app-env, *db-env, *redis-env, *minio-env, *aws-s3-env, *proxy-env]
    depends_on:
      - api
      - plane-db
      - plane-redis
      - plane-mq
    logging: *plane-logging

  migrator:
    container_name: plane_migrator
    image: makeplane/plane-backend:${APP_RELEASE:-stable}
    restart: "no"
    command: ./bin/docker-entrypoint-migrator.sh
    volumes:
      - logs_migrator:/code/plane/logs
    environment:
      <<: [*app-env, *db-env, *redis-env, *minio-env, *aws-s3-env, *proxy-env]
    depends_on:
      - plane-db
      - plane-redis
    logging: *plane-logging

  plane-db:
    container_name: plane_db
    image: {{ plane_postgres_image }}
    restart: {{ restart_policy }}
    command: postgres -c 'max_connections=1000'
    environment:
      <<: *db-env
    volumes:
      - pgdata:/var/lib/postgresql/data
    logging: *plane-logging

  plane-redis:
    container_name: plane_redis
    image: {{ plane_redis_image }}
    restart: {{ restart_policy }}
    volumes:
      - redisdata:/data
    logging: *plane-logging

  plane-mq:
    container_name: plane_mq
    image: {{ plane_mq_image }}
    restart: {{ restart_policy }}
    environment:
      <<: *mq-env
    volumes:
      - rabbitmq_data:/var/lib/rabbitmq
    logging: *plane-logging

  plane-minio:
    container_name: plane_minio
    image: {{ plane_minio_image }}
    restart: {{ restart_policy }}
    command: server /export --console-address ":9090"
    environment:
      <<: *minio-env
    volumes:
      - uploads:/export
    logging: *plane-logging

  proxy:
    container_name: plane_proxy
    image: makeplane/plane-proxy:${APP_RELEASE:-stable}
    restart: {{ restart_policy }}
    environment:
      <<: *proxy-env
    depends_on:
      - web
      - api
      - space
    networks:
      - default
      - proxy
    labels:
      traefik.enable: "true"
      traefik.docker.network: "{{ proxy_network }}"
      traefik.http.routers.plane.rule: "Host(`{{ plane_domain }}`)"
      traefik.http.routers.plane.entrypoints: "websecure"
      traefik.http.routers.plane.tls.certresolver: "letsencrypt"
      traefik.http.services.plane.loadbalancer.server.port: "80"
    logging: *plane-logging

volumes:
  pgdata:
    name: plane-pgdata
  redisdata:
    name: plane-redisdata
  uploads:
    name: plane-uploads
  rabbitmq_data:
    name: plane-rabbitmq-data
  logs_api:
    name: plane-logs-api
  logs_worker:
    name: plane-logs-worker
  logs_beat-worker:
    name: plane-logs-beat-worker
  logs_migrator:
    name: plane-logs-migrator

networks:
  default:
    name: plane-internal
  proxy:
    name: {{ proxy_network }}
    external: true
