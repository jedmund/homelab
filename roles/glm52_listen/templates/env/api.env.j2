# {{ ansible_managed }}
# Secret-bearing backend env for the listen (glm52) Rails API. Shared by the
# api, worker, and watcher services. Non-secret config stays inline in
# compose.yaml. All values below are sourced from vault.
SECRET_KEY_BASE={{ glm52_listen_secret_key_base }}
DATABASE_URL=postgres://{{ glm52_listen_db_user }}:{{ glm52_listen_db_password }}@postgres:5432/{{ glm52_listen_db_name }}
OIDC_CLIENT_ID={{ glm52_listen_oidc_client_id }}
OIDC_CLIENT_SECRET={{ glm52_listen_oidc_client_secret }}
LASTFM_API_KEY={{ glm52_listen_lastfm_api_key }}
LASTFM_API_SECRET={{ glm52_listen_lastfm_api_secret }}
