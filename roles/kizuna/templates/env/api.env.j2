# {{ ansible_managed }}
# Kizuna API + worker environment.  Same file is mounted into both
# containers; the worker reads only the bits it needs.

RAILS_ENV=production
RAILS_LOG_TO_STDOUT=1
RAILS_LOG_LEVEL=info
SECRET_KEY_BASE={{ kizuna_secret_key_base }}

# Active Record Encryption — encrypts AI-connection API keys at rest. The
# api and worker both need identical values (the worker decrypts a
# connection's key to run embeddings/chat). Set once, never rotate.
AR_ENCRYPTION_PRIMARY_KEY={{ kizuna_ar_encryption_primary_key }}
AR_ENCRYPTION_DETERMINISTIC_KEY={{ kizuna_ar_encryption_deterministic_key }}
AR_ENCRYPTION_KEY_DERIVATION_SALT={{ kizuna_ar_encryption_key_derivation_salt }}

# Database
DATABASE_HOST=kizuna-postgres
DATABASE_PORT=5432
DATABASE_NAME={{ kizuna_postgres_db }}
DATABASE_USER={{ kizuna_postgres_user }}
DATABASE_PASSWORD={{ kizuna_postgres_password }}

# Redis (Sidekiq)
REDIS_URL=redis://kizuna-redis:6379/0

# Storage — point the S3 adapter at the per-stack Garage instance.
# The bucket and credentials are created by garage_bootstrap.sh on
# first deploy (or imported from the vault if they were generated
# offline).
KIZUNA_STORAGE_BACKEND=s3
KIZUNA_S3_ENDPOINT=http://kizuna-garage:3900
KIZUNA_S3_REGION=garage
KIZUNA_S3_BUCKET={{ kizuna_garage_bucket }}
KIZUNA_S3_ACCESS_KEY_ID={{ kizuna_garage_access_key_id }}
KIZUNA_S3_SECRET_ACCESS_KEY={{ kizuna_garage_secret_access_key }}
KIZUNA_S3_FORCE_PATH_STYLE=true

# Public-facing URLs.
KIZUNA_API_BASE_URL={{ kizuna_api_origin }}
KIZUNA_ALLOWED_ORIGINS={{ kizuna_allowed_origins }}

# OIDC against PocketID.  Rails reads these via
# config/initializers/omniauth.rb; placeholders fail loud at the
# first OIDC request rather than booting with a half-configured
# provider.
KIZUNA_OIDC_ISSUER={{ kizuna_oidc_issuer }}
KIZUNA_OIDC_CLIENT_ID={{ kizuna_oidc_client_id }}
KIZUNA_OIDC_CLIENT_SECRET={{ kizuna_oidc_client_secret }}
KIZUNA_OIDC_REDIRECT_URI={{ kizuna_oidc_redirect_uri }}

# Session cookie scoped to the parent domain so the SPA at
# {{ kizuna_web_domain }} and the API at {{ kizuna_api_domain }}
# share session state across the subdomain boundary.
KIZUNA_COOKIE_DOMAIN={{ kizuna_cookie_domain }}
