# {{ ansible_managed }}
# Kizuna Postgres bootstrap env — consumed by the official postgres
# image's entrypoint on first start.  After the data dir is
# initialized these are read but ignored; changing them post-init
# requires a manual ALTER USER / CREATE DATABASE.

POSTGRES_USER={{ kizuna_postgres_user }}
POSTGRES_PASSWORD={{ kizuna_postgres_password }}
POSTGRES_DB={{ kizuna_postgres_db }}
