# {{ ansible_managed }}
# Screenshotter sidecar (Node + Playwright). Called by kizuna-api's
# CaptureScreenshotsJob / FetchNodeContentJob over the backend network at
# http://kizuna-screenshotter:4000/capture.

# Listen port — must match the port kizuna-api targets via SCREENSHOTTER_URL
# (the image also defaults PORT=4000).
PORT=4000

# Shared secret checked against the API's X-Screenshot-Secret header. Must
# equal SCREENSHOTTER_SECRET in api.env. Blank disables the check.
SCREENSHOT_SECRET={{ kizuna_screenshotter_secret }}
