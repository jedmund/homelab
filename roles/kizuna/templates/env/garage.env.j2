# {{ ansible_managed }}
# Garage process env.  Cluster + key + bucket creation are NOT
# auto-bootstrapped from here — see garage_bootstrap.sh for the
# idempotent setup.  Only the admin / metrics tokens live here so
# the bootstrap script (and any future ops invocations) can
# authenticate against the admin API.

RUST_LOG=garage=info
GARAGE_ADMIN_TOKEN={{ kizuna_garage_admin_token }}
GARAGE_METRICS_TOKEN={{ kizuna_garage_metrics_token }}
