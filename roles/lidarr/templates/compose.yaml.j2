# {{ ansible_managed }}
name: {{ stack_name }}

services:
  lidarr:
    image: {{ lidarr_image }}
    container_name: lidarr
    restart: {{ restart_policy }}
    networks:
      - shared
    ports:
      - "{{ lidarr_port }}:8686"
    environment:
      - TZ={{ timezone }}
      - PUID={{ puid }}
      - PGID={{ pgid }}
    volumes:
      - ./config:/config
      - music:/music
      - downloads:/downloads
    healthcheck:
      test: ["CMD", "curl", "-fsS", "-o", "/dev/null", "http://localhost:8686/ping"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  music:
    name: music
    external: true
  downloads:
    name: downloads
    external: true

networks:
  shared:
    name: {{ shared_network }}
    external: true
