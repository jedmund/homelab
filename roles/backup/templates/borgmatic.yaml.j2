# {{ ansible_managed }}
# Borgmatic configuration for nuc-mini local Borg repo.
# Repo lives on local disk at {{ borg_repo_host_path }}; rsync ships
# new segments to the NFS-mounted UniFi Drive share after each successful run.
#
# This file contains secrets (DB passwords, healthchecks URL, passphrase)
# templated inline from vault. Deployed with mode 0600.

source_directories:
{% for path in borg_source_paths %}
    - {{ path }}
{% endfor %}
    - {{ borg_dumps_container_path }}

repositories:
    - path: {{ borg_repo_container_path }}
      label: {{ borg_repo_label }}

exclude_patterns:
{% for pattern in borg_exclude_patterns %}
    - {{ pattern }}
{% endfor %}

encryption_passphrase: "{{ borg_passphrase }}"

# Retention: roll snapshots off after one month.
keep_daily: {{ borg_keep_daily }}

# Compression
compression: {{ borg_compression }}

# Integrity checks
checks:
    - name: repository
      frequency: {{ borg_check_repository_frequency }}
    - name: archives
      frequency: {{ borg_check_archives_frequency }}

# Native PostgreSQL hooks: dumps stream directly into the archive without
# touching local disk. Each entry connects to the DB container by name
# over its docker network.
postgresql_databases:
    - name: {{ immich_db_name }}
      hostname: immich_postgres
      username: {{ immich_db_username }}
      password: "{{ immich_db_password }}"
    - name: {{ mastodon_db_name }}
      hostname: mastodon_postgres
      username: {{ mastodon_db_user }}
      password: "{{ mastodon_db_password }}"
    - name: {{ synapse_db_name }}
      hostname: synapse_postgres
      username: {{ synapse_db_user }}
      password: "{{ synapse_db_password }}"
    - name: {{ mas_db_name }}
      hostname: mas_postgres
      username: {{ mas_db_user }}
      password: "{{ mas_db_password }}"
    - name: {{ n8n_db_name }}
      hostname: n8n_postgres
      username: {{ n8n_db_user }}
      password: "{{ n8n_db_password }}"
    - name: {{ miniflux_db_name }}
      hostname: miniflux-db
      username: {{ miniflux_db_user }}
      password: "{{ miniflux_db_password }}"
    - name: {{ forgejo_db_name }}
      hostname: forgejo_postgres
      username: {{ forgejo_db_user }}
      password: "{{ forgejo_db_password }}"
    - name: {{ blinko_db_name }}
      hostname: blinko_postgres
      username: {{ blinko_db_user }}
      password: "{{ blinko_db_password }}"
    - name: {{ draftboard_db_name }}
      hostname: draftboard_postgres
      username: {{ draftboard_db_user }}
      password: "{{ draftboard_db_password }}"

# Native MariaDB hook for RomM. Using root since MARIADB_ROOT_PASSWORD is
# what's set on the container; mysqldump needs LOCK TABLES which the romm
# user may not have.
mariadb_databases:
    - name: all
      hostname: romm-db
      username: root
      password: "{{ romm_db_root_password }}"

# Native MongoDB hook for Komodo. Dumps the admin database which contains
# Komodo's stack and deploy state.
mongodb_databases:
    - name: all
      hostname: komodo_mongo
      authentication_database: admin
      username: {{ komodo_db_username }}
      password: "{{ komodo_db_password }}"

# Custom dumps for CouchDB and SQLite plus the post-backup rsync to NAS.
# The dump scripts write to {{ borg_dumps_container_path }} (also in
# source_directories), so the resulting files land in the same archive.
commands:
    - before: action
      when:
          - create
      run:
          - /scripts/dump-couchdb.sh
          - /scripts/dump-sqlite.sh
    - after: action
      when:
          - create
      run:
          - /scripts/post-backup-rsync.sh

# Monitoring: ping Healthchecks.io after each run.
healthchecks:
    ping_url: "{{ borg_healthchecks_url }}"
    send_logs: {{ borg_healthchecks_send_logs | string | lower }}
    verify_tls: {{ borg_healthchecks_verify_tls | string | lower }}
    states:
{% for state in borg_healthchecks_states %}
        - {{ state }}
{% endfor %}
