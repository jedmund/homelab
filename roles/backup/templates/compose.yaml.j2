# {{ ansible_managed }}
name: {{ stack_name }}

services:
  borgmatic:
    container_name: borgmatic
    build:
      context: ./build
      dockerfile: Dockerfile
    restart: {{ restart_policy }}
    env_file:
      - ./env/borgmatic.env
    networks:
{% for net in borg_networks %}
      - {{ net }}
{% endfor %}
    volumes:
      - ./config/borgmatic:/etc/borgmatic.d:ro
      - ./scripts:/scripts:ro
      - {{ borg_repo_host_path }}:{{ borg_repo_container_path }}
      - {{ borg_dumps_host_path }}:{{ borg_dumps_container_path }}
      - {{ nas_mount_host_path }}:{{ nas_mount_container_path }}
{% for path in borg_source_paths %}
      - {{ path }}:{{ path }}:ro
{% endfor %}
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  borg-ui:
    container_name: borg-ui
    image: {{ borg_ui_image }}
    restart: {{ restart_policy }}
    environment:
      - TZ={{ timezone }}
      - PORT={{ borg_ui_container_port }}
      - PUBLIC_BASE_URL=https://{{ borg_ui_domain }}
    networks:
      - proxy-network
    volumes:
      - borg-ui-data:/data
      - {{ borg_repo_host_path }}:{{ borg_repo_container_path }}:ro
    labels:
      traefik.enable: "true"
      traefik.docker.network: proxy-network
      traefik.http.routers.borg-ui.rule: "Host(`{{ borg_ui_domain }}`)"
      traefik.http.routers.borg-ui.entrypoints: "websecure"
      traefik.http.routers.borg-ui.tls.certresolver: "letsencrypt"
      traefik.http.services.borg-ui.loadbalancer.server.port: "{{ borg_ui_container_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  borg-ui-data:

networks:
{% for net in borg_networks %}
  {{ net }}:
    name: {{ net }}
    external: true
{% endfor %}
