#!/usr/bin/env bash
# {{ ansible_managed }}
# Use sqlite3's .backup command to produce a consistent snapshot of each
# tracked SQLite database. Plain `cp` of a live SQLite file can capture
# inconsistent WAL state; .backup uses the SQLite backup API which is
# safe with concurrent writers.
#
# Output lands in {{ borg_dumps_container_path }}/sqlite/, which is part
# of the borg source path; the next snapshot picks them up.
#
# Per-file failures (one DB locked, missing, or unreadable) are logged
# but don't abort the rest of the list. Final exit code is 0 as long as
# at least one DB dumped, so borgmatic continues with the files that
# DID work. Summary of failures emitted on stderr.

set -uo pipefail

DUMP_DIR="{{ borg_dumps_container_path }}/sqlite"
mkdir -p "$DUMP_DIR"

# Clean previous dumps so we don't carry stale state across runs.
shopt -s nullglob
rm -f "$DUMP_DIR"/*.db "$DUMP_DIR"/*.sqlite "$DUMP_DIR"/*.sqlite3
shopt -u nullglob

# Path inside the borgmatic container (read-only mount of /opt/docker).
# Update the list as stacks add or move SQLite-backed services. Paths with
# spaces are fine since each array entry is a separately-quoted string.
SQLITE_FILES=(
    "/opt/docker/infra-gateway/config/pocketid/data/pocket-id.db"
    "/opt/docker/content-management/config/papra/db/db.sqlite"
    "/opt/docker/content-management/config/homebox/homebox.db"
    "/opt/docker/content-management/album-sort-data/album-sort.db"
    "/opt/docker/media-acquisition/config/sonarr/sonarr.db"
    "/opt/docker/media-acquisition/config/radarr/radarr.db"
    "/opt/docker/media-acquisition/config/lidarr/lidarr.db"
    "/opt/docker/media-acquisition/config/prowlarr/prowlarr.db"
    "/opt/docker/media-acquisition/config/qui/qui.db"
    "/opt/docker/media-acquisition/config/pinchflat/db/pinchflat.db"
    "/opt/docker/media-consumption/config/kavita/kavita.db"
    "/opt/docker/media-consumption/config/stash/stash-go.sqlite"
    "/opt/docker/media-consumption/config/tunarr/db.db"
    "/opt/docker/media-consumption/config/plex/Library/Application Support/Plex Media Server/Plug-in Support/Databases/com.plexapp.plugins.library.db"
    "/opt/docker/media-consumption/config/plex/Library/Application Support/Plex Media Server/Plug-in Support/Databases/com.plexapp.plugins.library.blobs.db"
)

FAILED=()
SUCCEEDED=0

for src in "${SQLITE_FILES[@]}"; do
    if [ ! -f "$src" ]; then
        echo "dump-sqlite: skipping missing ${src}" >&2
        continue
    fi
    rel="${src#/opt/docker/}"
    dest="${DUMP_DIR}/${rel//\//_}"
    echo "dump-sqlite: ${src} -> ${dest}"
    if sqlite3 "$src" ".backup '${dest}'"; then
        SUCCEEDED=$((SUCCEEDED + 1))
    else
        echo "dump-sqlite: FAILED on ${src}" >&2
        rm -f "${dest}"
        FAILED+=("$src")
    fi
done

echo "dump-sqlite: ${SUCCEEDED} succeeded, ${#FAILED[@]} failed"
if [ "${#FAILED[@]}" -gt 0 ]; then
    echo "dump-sqlite: failed files:" >&2
    printf '  - %s\n' "${FAILED[@]}" >&2
fi

# Exit 0 as long as at least one DB dumped. A complete shutout (every DB
# unreadable) probably means something structural is wrong and is worth
# failing on.
[ "$SUCCEEDED" -gt 0 ]
