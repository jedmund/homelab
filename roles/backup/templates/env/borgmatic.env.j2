# {{ ansible_managed }}
# Borgmatic container env. The Borg binary reads BORG_PASSPHRASE natively
# for repo operations; everything else lives inline in borgmatic.yaml,
# which is mode 0600.

BORG_PASSPHRASE={{ borg_passphrase }}
BACKUP_CRON={{ borg_backup_cron }}
RUN_ON_STARTUP={{ borg_run_on_startup }}
TZ={{ timezone }}

# CouchDB credentials are read from env by /scripts/dump-couchdb.sh.
COUCHDB_USER={{ couchdb_user }}
COUCHDB_PASSWORD={{ couchdb_password }}
