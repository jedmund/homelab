# {{ ansible_managed }}
# Borgmatic env: passphrase, schedule, and per-DB credentials passed through
# from each stack's vault. borgmatic.yaml references these via the
# {credential env VAR} syntax.

BORG_PASSPHRASE={{ borg_passphrase }}
BACKUP_CRON={{ borg_backup_cron }}
RUN_ON_STARTUP={{ borg_run_on_startup }}
TZ={{ timezone }}

# PostgreSQL passwords
IMMICH_DB_PASSWORD={{ immich_db_password }}
MASTODON_DB_PASSWORD={{ mastodon_db_password }}
SYNAPSE_DB_PASSWORD={{ synapse_db_password }}
MAS_DB_PASSWORD={{ mas_db_password }}
N8N_DB_PASSWORD={{ n8n_db_password }}
MINIFLUX_DB_PASSWORD={{ miniflux_db_password }}
FORGEJO_DB_PASSWORD={{ forgejo_db_password }}
BLINKO_DB_PASSWORD={{ blinko_db_password }}
DRAFTBOARD_DB_PASSWORD={{ draftboard_db_password }}

# MariaDB (RomM)
ROMM_DB_ROOT_PASSWORD={{ romm_db_root_password }}

# MongoDB (Komodo)
KOMODO_DB_PASSWORD={{ komodo_db_password }}

# CouchDB (Obsidian LiveSync) - consumed by /scripts/dump-couchdb.sh
COUCHDB_USER={{ couchdb_user }}
COUCHDB_PASSWORD={{ couchdb_password }}

# Healthchecks.io ping URL (the URL itself is the secret per-check identifier)
HEALTHCHECKS_PING_URL={{ borg_healthchecks_url }}
