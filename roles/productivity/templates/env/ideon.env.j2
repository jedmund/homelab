# {{ ansible_managed }}
# Ideon environment variables - generated from Ansible Vault

# App
APP_PORT={{ ideon_port }}
APP_URL={{ ideon_app_url }}
TIMEZONE={{ timezone }}
LOG_LEVEL_SERVER={{ ideon_log_level_server }}
LOG_LEVEL_CLIENT={{ ideon_log_level_client }}

# Security
# ideon_secret_key - defined in vault
SECRET_KEY={{ ideon_secret_key }}

# Database
DB_HOST={{ ideon_db_host }}
DB_PORT={{ ideon_db_port }}
DB_NAME={{ ideon_db_name }}
DB_USER={{ ideon_db_user }}
# ideon_db_password - defined in vault
DB_PASS={{ ideon_db_password }}

# SMTP
SMTP_HOST={{ ideon_smtp_host }}
SMTP_PORT={{ ideon_smtp_port }}
SMTP_USER={{ ideon_smtp_user }}
# ideon_smtp_password - defined in vault
SMTP_PASSWORD={{ ideon_smtp_password }}
SMTP_FROM_EMAIL={{ ideon_smtp_from_email }}
SMTP_FROM_NAME={{ ideon_smtp_from_name }}
SMTP_USE_TLS={{ ideon_smtp_use_tls }}
