// {{ ansible_managed }}
// Renovate self-hosted config. Loaded via RENOVATE_CONFIG_FILE; everything
// here is overridable by per-repo .renovaterc.json once onboarding lands.

module.exports = {
  platform: '{{ renovate_platform }}',
  endpoint: '{{ renovate_endpoint }}',
  // Renovate runs on the `backend` docker network, which is `internal: true`
  // and has no egress. API calls go to GitLab over `http://gitlab` (the
  // endpoint above), but `git clone` defaults to the URL GitLab returns in
  // `http_url_to_repo`, i.e. https://git.atelier.house/..., which the
  // renovate container has no route to. Setting gitUrl: 'endpoint' makes
  // Renovate clone from the same host/protocol as the API endpoint, so
  // clones happen over `http://gitlab/...` on the backend network.
  gitUrl: 'endpoint',
  gitAuthor: '{{ renovate_git_author }}',
  autodiscover: {{ renovate_autodiscover }},
  onboarding: {{ renovate_onboarding }},
  onboardingConfig: {
    extends: ['config:recommended'],
  },
  // GitLab is self-signed via Lets Encrypt through Traefik; no extra CA needed.
};
