# {{ ansible_managed }}
#
# Minimal Mosquitto config for the petlibro stack.
# Anonymous, local-network only. NOT exposed to the internet — the LAN
# perimeter (UDM firewall) provides isolation.

listener 1883 0.0.0.0
allow_anonymous true

persistence true
persistence_location /mosquitto/data/

log_dest stdout
log_type error
log_type warning
log_type notice
log_type information

# Keep at most a week of persisted state — feeders republish on reconnect
autosave_interval 60
