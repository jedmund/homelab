# {{ ansible_managed }}
name: {{ stack_name }}

services:
{% for m in sglang_models %}
  {{ m.name }}:
    image: {{ m.image | default(sglang_image) }}
    container_name: {{ m.name }}
    # Manual lifecycle: don't auto-restart heavy models. If a model
    # crashes, we want to know about it rather than silently churn.
    restart: "no"
    # Profiles gate startup. `docker compose up` with no --profile
    # starts nothing; `--profile {{ m.name }}` starts just this model.
    # The "all" profile is a convenience for bringing every catalog
    # entry up at once (use only when you know VRAM allows it).
    profiles: ["{{ m.name }}", "all"]
    ports:
      - {{ m.host_port }}:{{ m.container_port }}
    volumes:
      - ./models:/models:ro
      # Whole-cache mount (not just huggingface/) so SGLang's JIT
      # kernel cache and any per-image cache locations land on the
      # same persistent volume. The community DSV4 compose does this.
      - hf-cache:/root/.cache
      - jit-cache:/cache/jit
      # Explicit /dev/shm bind mount: with ipc:host + shm_size set,
      # Docker can give the container a separate /dev/shm tmpfs that
      # isn't actually the host's shared memory. Without this bind,
      # sglang's pynccl wrapper fails ncclCommInitRank with a generic
      # ncclSystemError that produces zero NCCL debug output (the
      # failure is inside the cudaIpc layer before NCCL's logger
      # fires). Took half a day to track down the first time; do not
      # remove without re-running multi-GPU TP smoke tests.
      - /dev/shm:/dev/shm
    # ipc: host + a generous shm are NCCL prerequisites for multi-GPU
    # tensor parallelism. Without them, --tp 2 deadlocks at startup.
    ipc: host
    shm_size: {{ m.shm_size | default(sglang_default_shm_size) }}
    ulimits:
      memlock: -1
      stack: 67108864
      nofile: 1048576
    environment:
{% for k, v in sglang_common_env.items() %}
      {{ k }}: "{{ v }}"
{% endfor %}
{% for k, v in (m.extra_env | default({})).items() %}
      {{ k }}: "{{ v }}"
{% endfor %}
{% if m.cuda_visible_devices is defined %}
      CUDA_VISIBLE_DEVICES: "{{ m.cuda_visible_devices }}"
{% endif %}
    # Old-style `gpus: all` rather than the newer
    # `deploy.resources.reservations.devices` block. The newer syntax
    # somehow breaks sglang's pynccl multi-GPU init on this image (also
    # part of the half-day NCCL debug). `gpus: all` works; matches the
    # community DSV4 compose. If a future model needs a different GPU
    # selection, add per-model `cuda_visible_devices` to constrain the
    # set the container actually uses.
    gpus: all
    # voipmonitor's image has its own entrypoint that doesn't pass
    # flag-only argv through cleanly (bash `exec "$@"` errors on a
    # leading `--`). Override the entrypoint with the full launcher
    # invocation, matching their own example compose files.
    entrypoint:
      - python3
      - -m
      - sglang.launch_server
{% for arg in m.args %}
      - {{ arg }}
{% endfor %}
    healthcheck:
      test: ["CMD", "curl", "-fsS", "-o", "/dev/null", "http://localhost:{{ m.container_port }}/health"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
      # Cold-load tax for a ~140 GB NVFP4 model from NVMe -> VRAM is
      # ~60-90s on this box; 180s gives margin for the JIT warmup that
      # follows the weight load.
      start_period: 180s
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}
{% endfor %}

volumes:
  hf-cache:
  jit-cache:
