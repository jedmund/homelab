# {{ ansible_managed }}
# GitLab Runner config. Owned by Ansible; runner does not write back to
# this file outside `register`/`verify`, and we never call those — the
# auth token comes from vault directly.

concurrent = {{ gitlab_runner_concurrent }}
check_interval = 0
log_level = "{{ gitlab_runner_log_level }}"
shutdown_timeout = 0

[session_server]
  session_timeout = 1800

[[runners]]
  name = "{{ gitlab_runner_name }}"
  url = "{{ gitlab_root_url }}/"
  id = 0
  token = "{{ gitlab_runner_auth_token }}"
  token_obtained_at = 1970-01-01T00:00:00Z
  token_expires_at = 0001-01-01T00:00:00Z
  executor = "docker"
  [runners.cache]
    MaxUploadedArchiveSize = 0
    [runners.cache.s3]
    [runners.cache.gcs]
    [runners.cache.azure]
  [runners.docker]
    tls_verify = false
    image = "{{ gitlab_runner_default_image }}"
    privileged = false
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    network_mode = "{{ backend_network }}"
    volumes = ["/var/run/docker.sock:/var/run/docker.sock", "/cache"]
    shm_size = 0
    network_mtu = 0
