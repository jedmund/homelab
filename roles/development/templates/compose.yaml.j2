# {{ ansible_managed }}
name: {{ stack_name }}

services:
  gitlab:
    container_name: gitlab
    image: {{ gitlab_image }}
    restart: {{ restart_policy }}
    hostname: {{ gitlab_domain }}
    shm_size: {{ gitlab_shm_size }}
    networks:
      - proxy
      - backend
      - cibuild
    ports:
      - "{{ gitlab_ssh_port }}:22"
    volumes:
      - ./gitlab/config:/etc/gitlab
      - ./gitlab/logs:/var/log/gitlab
      - ./gitlab/data:/var/opt/gitlab
    env_file:
      - ./env/gitlab.env
    healthcheck:
      test: ["CMD", "/opt/gitlab/bin/gitlab-healthcheck", "--fail", "--max-time", "10"]
      interval: 60s
      timeout: 30s
      retries: 5
      start_period: 600s
    labels:
      traefik.enable: "true"
      traefik.http.routers.gitlab.rule: "Host(`{{ gitlab_domain }}`)"
      traefik.http.routers.gitlab.entrypoints: "websecure"
      traefik.http.routers.gitlab.tls.certresolver: "letsencrypt"
      traefik.http.routers.gitlab.service: "gitlab"
      traefik.http.services.gitlab.loadbalancer.server.port: "{{ gitlab_web_port }}"
      traefik.http.routers.gitlab-registry.rule: "Host(`{{ gitlab_registry_domain }}`)"
      traefik.http.routers.gitlab-registry.entrypoints: "websecure"
      traefik.http.routers.gitlab-registry.tls.certresolver: "letsencrypt"
      traefik.http.routers.gitlab-registry.service: "gitlab-registry"
      traefik.http.services.gitlab-registry.loadbalancer.server.port: "{{ gitlab_registry_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  gitlab-runner:
    container_name: gitlab_runner
    image: {{ gitlab_runner_image }}
    restart: {{ restart_policy }}
    networks:
      - backend
      - cibuild
    volumes:
      - ./gitlab-runner/config:/etc/gitlab-runner
      - /var/run/docker.sock:/var/run/docker.sock
    depends_on:
      gitlab:
        condition: service_healthy
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  renovate:
    container_name: renovate
    image: {{ renovate_image }}
    restart: "no"
    # Renovate is a one-shot CLI driven by the host cron (see role tasks).
    # Keeping it in the default profile leaves an Exited container behind
    # after each run, which Komodo surfaces as the whole development stack
    # going unhealthy. The `cron` profile excludes it from `compose up` /
    # `compose ps` while `compose run --rm renovate` still works because
    # `run` activates a named service regardless of profile.
    profiles:
      - cron
    # `backend` reaches GitLab via `http://gitlab` for API + clones (see
    # config.js gitUrl). `cibuild` (a non-internal bridge) is what gives
    # renovate egress to Docker Hub, npm, PyPI, crates.io, GitHub, etc.
    # for dependency tag lookups; without it every datasource lookup
    # fails with EAI_AGAIN and no updates get proposed.
    networks:
      - backend
      - cibuild
    env_file:
      - ./env/renovate.env
    volumes:
      - ./renovate/config.js:/usr/src/app/config.js:ro
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  open-webui:
    container_name: open_webui
    image: {{ open_webui_image }}
    restart: {{ restart_policy }}
    networks:
      - proxy
    volumes:
      - open-webui-data:/app/backend/data
    environment:
      - OLLAMA_BASE_URL={{ open_webui_ollama_base_url }}
      - OPENAI_API_BASE_URL={{ open_webui_openai_api_base_url }}
      - WEBUI_AUTH={{ open_webui_auth }}
      - WEBUI_URL={{ open_webui_url }}
      - WEBUI_SECRET_KEY={{ open_webui_secret_key }}
      # Per-user API keys (Settings -> Account -> API keys). Required for
      # external clients (OpenCode, Claude Code, etc.) to hit OpenWebUI's
      # OpenAI-compatible endpoints with a user-scoped bearer token.
      # Endpoint restrictions stay enabled so a leaked personal key can't
      # be used to call admin routes.
      - ENABLE_API_KEYS=true
      - ENABLE_API_KEYS_ENDPOINT_RESTRICTIONS=true
      - ENABLE_OAUTH_SIGNUP={{ open_webui_oauth_signup }}
      - OAUTH_MERGE_ACCOUNTS_BY_EMAIL={{ open_webui_oauth_merge_accounts }}
      - OAUTH_PROVIDER_NAME={{ open_webui_oauth_provider_name }}
      - OPENID_PROVIDER_URL={{ open_webui_oidc_provider_url }}
      - OAUTH_CLIENT_ID={{ open_webui_oauth_client_id }}
      - OAUTH_CLIENT_SECRET={{ open_webui_oauth_client_secret }}
      - OAUTH_SCOPES={{ open_webui_oauth_scopes }}
      # Speech-to-text via whisper (speaches) on max
      - AUDIO_STT_ENGINE=openai
      - AUDIO_STT_OPENAI_API_BASE_URL={{ open_webui_audio_stt_base_url }}
      - AUDIO_STT_OPENAI_API_KEY=sk-no-key-required
      - AUDIO_STT_MODEL=Systran/faster-distil-whisper-large-v3
      # Text-to-speech via kokoro-fastapi on max
      - AUDIO_TTS_ENGINE=openai
      - AUDIO_TTS_OPENAI_API_BASE_URL={{ open_webui_audio_tts_base_url }}
      - AUDIO_TTS_OPENAI_API_KEY=sk-no-key-required
      - AUDIO_TTS_MODEL=kokoro
      - AUDIO_TTS_VOICE={{ open_webui_audio_tts_voice }}
      # RAG web search via SearXNG on max
      - ENABLE_RAG_WEB_SEARCH=true
      - RAG_WEB_SEARCH_ENGINE=searxng
      - SEARXNG_QUERY_URL={{ open_webui_searxng_query_url }}
      # Web page scraping via Playwright (also on max). Replaces the
      # default LangChain httpx loader, which most sites block.
      - WEB_LOADER_ENGINE={{ open_webui_web_loader_engine }}
      - PLAYWRIGHT_WS_URL={{ open_webui_playwright_ws_url }}
      # RAG embeddings via TEI (HuggingFace text-embeddings-inference) on max
      - RAG_EMBEDDING_ENGINE=openai
      - RAG_OPENAI_API_BASE_URL={{ open_webui_rag_embedding_base_url }}
      - RAG_OPENAI_API_KEY=sk-no-key-required
      - RAG_EMBEDDING_MODEL={{ open_webui_rag_embedding_model }}
    labels:
      traefik.enable: "true"
      traefik.http.routers.open-webui.rule: "Host(`{{ open_webui_domain }}`)"
      traefik.http.routers.open-webui.entrypoints: "websecure"
      traefik.http.routers.open-webui.tls.certresolver: "letsencrypt"
      traefik.http.services.open-webui.loadbalancer.server.port: "{{ open_webui_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  paseo-relay:
    container_name: paseo_relay
    image: {{ paseo_relay_image }}
    restart: {{ restart_policy }}
    networks:
      - proxy
    ports:
      - "{{ paseo_relay_port }}:{{ paseo_relay_port }}"
    environment:
      - LOG_FORMAT=json
    labels:
      traefik.enable: "true"
      traefik.http.routers.paseo-relay.rule: "Host(`{{ paseo_relay_domain }}`)"
      traefik.http.routers.paseo-relay.entrypoints: "websecure"
      traefik.http.routers.paseo-relay.tls.certresolver: "letsencrypt"
      # paseo-relay is WebSocket-only; HTTP/2 ALPN breaks Upgrade.
      # Force HTTP/1.1 ALPN so Electron / iOS / browser clients
      # fall back to HTTP/1.1 and the WS handshake succeeds.
      traefik.http.routers.paseo-relay.tls.options: "http1only@file"
      traefik.http.services.paseo-relay.loadbalancer.server.port: "{{ paseo_relay_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  vane:
    container_name: vane
    image: {{ vane_image }}
    restart: {{ restart_policy }}
    networks:
      - proxy
    volumes:
      - vane-data:/home/vane/data
    environment:
      # Override the bundled SearXNG (localhost:8080 inside the Vane
      # container) and route Vane's search to max's shared instance.
      - SEARXNG_API_URL={{ vane_searxng_url }}
    labels:
      traefik.enable: "true"
      traefik.http.routers.vane.rule: "Host(`{{ vane_domain }}`)"
      traefik.http.routers.vane.entrypoints: "websecure"
      traefik.http.routers.vane.tls.certresolver: "letsencrypt"
      traefik.http.routers.vane.middlewares: "tinyauth@file"
      traefik.http.services.vane.loadbalancer.server.port: "{{ vane_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  odysseus:
    container_name: odysseus
    build:
      context: ./odysseus-src
    restart: {{ restart_policy }}
    networks:
      - proxy
      - backend
    volumes:
      - ./odysseus/data:/app/data
      - ./odysseus/logs:/app/logs
      - ./odysseus/data/ssh:/app/.ssh
      - ./odysseus/data/huggingface:/app/.cache/huggingface
      - ./odysseus/data/local:/app/.local
    extra_hosts:
      # Lets the container reach local services on the docker host
      # (useful if you ever run a model server on nuc-mini itself
      # rather than on max).
      - "host.docker.internal:host-gateway"
    environment:
      # Odysseus's own login is on. Tinyauth in front is the network
      # gate; Odysseus's session is the per-user gate. Setting
      # AUTH_ENABLED=false isn't a true bypass: the UI still surfaces a
      # login page when users exist, and several endpoints (email,
      # research) 401 without a user context. Cheaper to accept the
      # double-login until we add native OIDC (see
      # [[project-vane-oidc-fork-followup]]).
      - AUTH_ENABLED=true
      # Mark the session cookie Secure. Default is false, which a
      # browser will drop on an HTTPS page (Traefik terminates TLS
      # in front) and the login becomes a redirect loop:
      # POST /login -> 200 + cookie -> browser drops -> next page has
      # no session -> /login again. Required for any deployment that
      # isn't plain HTTP localhost.
      - SECURE_COOKIES=true
      # Reuse max's SearXNG (the ai-stack one) instead of a per-stack copy.
      - SEARXNG_INSTANCE={{ odysseus_searxng_url }}
      - CHROMADB_HOST={{ odysseus_chromadb_host }}
      - CHROMADB_PORT={{ odysseus_chromadb_port }}
      - PUID={{ odysseus_puid }}
      - PGID={{ odysseus_pgid }}
    depends_on:
      odysseus-chromadb:
        condition: service_started
    labels:
      traefik.enable: "true"
      traefik.http.routers.odysseus.rule: "Host(`{{ odysseus_domain }}`)"
      traefik.http.routers.odysseus.entrypoints: "websecure"
      traefik.http.routers.odysseus.tls.certresolver: "letsencrypt"
      traefik.http.routers.odysseus.middlewares: "tinyauth@file"
      traefik.http.services.odysseus.loadbalancer.server.port: "{{ odysseus_port }}"
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  odysseus-chromadb:
    container_name: odysseus-chromadb
    image: {{ odysseus_chromadb_image }}
    restart: {{ restart_policy }}
    networks:
      - backend
    volumes:
      - odysseus-chromadb-data:/chroma/chroma
    environment:
      - ANONYMIZED_TELEMETRY=FALSE
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

  odysseus-ntfy:
    container_name: odysseus-ntfy
    image: {{ odysseus_ntfy_image }}
    restart: {{ restart_policy }}
    command: serve
    networks:
      - backend
    volumes:
      - odysseus-ntfy-cache:/var/cache/ntfy
    environment:
      - NTFY_BASE_URL={{ odysseus_ntfy_base_url }}
    logging:
      driver: {{ logging_driver }}
      options:
        max-size: {{ logging_max_size }}
        max-file: {{ logging_max_file }}

volumes:
  open-webui-data:
    external: true
  vane-data:
  odysseus-chromadb-data:
  odysseus-ntfy-cache:

networks:
  proxy:
    name: {{ proxy_network }}
    external: true
  backend:
    name: {{ backend_network }}
    external: true
  cibuild:
    name: {{ cibuild_network }}
    external: true
